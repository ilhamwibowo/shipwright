# Required
ANTHROPIC_API_KEY=sk-ant-...

# Repository to work on (default: current directory)
# REPO_ROOT=/path/to/your/project

# Model selection (default: claude-sonnet-4-6)
# AGENT_MODEL=claude-sonnet-4-6

# Agent limits
# MAX_FIX_ATTEMPTS=3           # Max QA-fix cycles before giving up
# MAX_BUDGET_PER_AGENT_USD=5.00  # Token budget per agent step
# AGENT_TIMEOUT_SECONDS=600    # Per-agent timeout (0 = no timeout)

# Telegram bot (optional)
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=987654321
# TELEGRAM_ALLOWED_USERS=username1,username2,123456789

# Discord bot (optional)
# DISCORD_BOT_TOKEN=MTIzNDU2...
# DISCORD_CHANNEL_ID=123456789
